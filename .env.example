# AutoReview environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────

# Anthropic API key for Claude LLM
ANTHROPIC_API_KEY=your-anthropic-api-key

# PubMed (NCBI Entrez) — free, but email is required
ENTREZ_EMAIL=your-email@example.com

# ── Recommended ───────────────────────────────────────────

# NCBI API key — raises PubMed rate limit from 3 to 10 req/s
# Get one at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=your-ncbi-api-key

# Semantic Scholar API key — raises rate limit
# Request at: https://www.semanticscholar.org/product/api#api-key
S2_API_KEY=your-s2-api-key

# OpenAlex polite pool — uses your email for higher rate limits
# See: https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_EMAIL=your-email@example.com

# Unpaywall — email required for API access
# See: https://unpaywall.org/products/api
UNPAYWALL_EMAIL=your-email@example.com

# ── Optional ──────────────────────────────────────────────

# Perplexity Sonar — AI-powered discovery of recent/under-indexed work
PERPLEXITY_API_KEY=your-perplexity-api-key

# Elsevier ScienceDirect — full-text retrieval for Elsevier journals
ELSEVIER_API_KEY=your-elsevier-api-key

# Springer Nature — full-text retrieval for Springer journals
SPRINGER_API_KEY=your-springer-api-key
